<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="blocks/student_registration/db" VERSION="2025082500" COMMENT="Student Registration Block" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../lib/xmldb/xmldb.xsd">

  <TABLES>
    <TABLE NAME="block_student_registration" COMMENT="Stores registered students">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" SEQUENCE="true" NOTNULL="true"/>
        <FIELD NAME="fullname" TYPE="char" LENGTH="255" NOTNULL="true"/>
        <FIELD NAME="email" TYPE="char" LENGTH="255" NOTNULL="true"/>
        <FIELD NAME="contact" TYPE="char" LENGTH="20" NOTNULL="false"/>
        <FIELD NAME="dob" TYPE="char" LENGTH="20" NOTNULL="false"/>
        <FIELD NAME="standard" TYPE="char" LENGTH="50" NOTNULL="false"/>
        <FIELD NAME="batch" TYPE="char" LENGTH="50" NOTNULL="false"/>
        <FIELD NAME="day" TYPE="char" LENGTH="50" NOTNULL="false"/>
        <FIELD NAME="time" TYPE="char" LENGTH="50" NOTNULL="false"/>
        <FIELD NAME="school" TYPE="char" LENGTH="255" NOTNULL="false"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
    </TABLE>
  </TABLES>

</XMLDB>

